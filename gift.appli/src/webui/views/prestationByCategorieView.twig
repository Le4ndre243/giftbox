{% extends 'base.html.twig' %}

{% block title %}Prestations - {{ categorie.libelle }}{% endblock %}

{% block content %}
    <h1>Prestations de la catégorie : {{ categorie.libelle }}</h1>
    <div class="prestations-grid">
        {% for p in prestations %}
            <a class="prestation-card" href="{{ url_for('prestation', {id: p.id}) }}">
                <img src="{{ img_dir }}/{{ p.img }}" alt="{{ p.libelle }}">
                <div class="prestation-card-body">
                    <h3>{{ p.libelle }}</h3>
                    <p class="prestation-prix">{{ p.tarif }} € / {{ p.unite }}</p>
                </div>
            </a>
        {% else %}
            <p>Aucune prestation pour cette catégorie.</p>
        {% endfor %}
    </div>
    <a href="{{ url_for('categories') }}">← Retour aux catégories</a>
{% endblock %}