{% extends 'base.html.twig' %}

{% block title %}Toutes les prestations{% endblock %}

{% block content %}
    <h1>Liste des prestations</h1>
    <div class="prestations-grid">
        {% for p in prestations %}
            <a class="prestation-card" href="{{ url_for('prestation', {id: p.id}) }}">
                <img src="{{ img_dir }}/{{ p.img }}" alt="{{ p.libelle }}">
                <div class="prestation-card-body">
                    <h3>{{ p.libelle }}</h3>
                    <p class="prestation-prix">{{ p.tarif }} € / {{ p.unite }}</p>
                    <p class="prestation-cat">{{ p.categorie.libelle }}</p>
                </div>
            </a>
        {% else %}
            <p>Aucune prestation disponible.</p>
        {% endfor %}
    </div>
{% endblock %}
