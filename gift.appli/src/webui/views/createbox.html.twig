{% extends 'base.html.twig' %}

{% block title %}Création d'une box{% endblock %}

{% block content %}
        <form action="{{ url_for('postBoxCreate') }}" method="post">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label for="name">Nom de la box :</label><br>
            <input type="text" id="name" name="name" value="{{ prefill_name|default('') }}" required><br>

            <label for="desc">Description de la box :</label><br>
            <textarea id="desc" name="desc">{{ prefill_desc|default('') }}</textarea><br>

            <label for="giftcheckbox">La box est un cadeau ?</label>
            <input type="checkbox" id="giftcheckbox" name="giftcheckbox" value="1"
                   onchange="document.getElementById('gift-message').style.display = this.checked ? 'block' : 'none'"><br>

            <div id="gift-message" style="display:none">
                <label for="giftmess">Message du cadeau :</label><br>
                <input type="text" id="giftmess" name="giftmess"><br>
            </div>

            <br>
            <button type="submit">Créer la box</button>
        </form>
{% endblock %}
