{% extends 'base.html.twig' %}

{% block title %}{{ prestation.libelle }}{% endblock %}

{% block content %}
    <div class="prestation-detail">
        <img class="prestation-detail-img" src="{{ img_dir }}/{{ prestation.img }}" alt="{{ prestation.libelle }}">
        <div class="prestation-detail-info">
            <h1>{{ prestation.libelle }}</h1>
            <p class="prestation-cat">Catégorie : <a href="{{ url_for('prestations_by_categorie', {id: categorie.id}) }}">{{ categorie.libelle }}</a></p>
            <p>{{ prestation.description }}</p>
            <p class="prestation-prix"><strong>{{ prestation.tarif }} €</strong> / {{ prestation.unite }}</p>
        </div>
    </div>
    {% if current_box_id and current_box_statut == 1 %}
        <form action="{{ url_for('addPrestation', {id: prestation.id}) }}" method="post">
            <button type="submit">Ajouter à ma box</button>
        </form>
    {% endif %}
    <a href="{{ url_for('prestations_by_categorie', {id: categorie.id}) }}">← Retour aux prestations de cette catégorie</a>
{% endblock %}