{% extends 'base.html.twig' %}

{% block title %}Box{% endblock %}

{% block content %}
    <h1>{{box.libelle}}</h1>
    {% if box.kdo == 1 %}
    <p><em>{{ box.message_kdo }}</em></p>
{% endif %}

    <div class="prestations-grid">
        {% for presta in box.prestations %}
            <a class="prestation-card" href="{{ url_for('prestation', {id: presta.id}) }}">
                <img src="{{ img_dir }}/{{ presta.img }}" alt="{{ presta.libelle }}">
                <div class="prestation-card-body">
                    <h3>{{ presta.libelle }}</h3>
                    <p class="prestation-prix">{% if box.kdo == 0 %}{{ presta.tarif }} € {%endif%} x {{ presta.pivot.quantite }}</p>
                    <p class="prestation-cat">{{ presta.categorie.libelle }}</p>
                </div>
            </a>
        {% else %}
            <p>Aucune prestation disponible.</p>
        {% endfor %}
    </div>

    {% if box.kdo == 0 %}
        {% set total = 0 %}
        {% for presta in box.prestations %}
            {% set total = total + presta.tarif * presta.pivot.quantite %}
        {% endfor %}
        <p><strong>Total : {{ total|number_format(2, ',', ' ') }}€</strong></p>
    {% endif %}
            <button onclick="window.print()">Imprimer</button>
            {%if box.statut === 1%}
                <a href="{{ url_for('validateBox', {id: box.id}) }}">
                    <button type="button">Valider</button>
                </a>
            {%endif%}
{% endblock %}