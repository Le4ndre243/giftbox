{% extends 'base.html.twig' %}

{% block title %}Thèmes{% endblock %}

{% block content %}
    <h1>Liste des thèmes</h1>
    <ul class="categories-list">
        {% for them in themes %}
            <li>
                <a href="{{ url_for('prestations_by_categorie', {id: them.id}) }}">{{ them.libelle }}</a>
            </li>
        {% endfor %}
    </ul>
{% endblock %}