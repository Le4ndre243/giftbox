{% extends 'base.html.twig' %}

{% block title %}Prestations - {{ categorie.libelle }}{% endblock %}

{% block content %}
    <h1>Prestations de la catégorie : {{ categorie.libelle }}</h1>
    <ul>
        {% for p in prestations %}
            <li>
                <a href="{{ url_for('prestation') }}?id={{ p.id }}">{{ p.libelle }}</a>
                - {{ p.tarif }} €/{{ p.unite }}
            </li>
        {% else %}
            <li>Aucune prestation pour cette catégorie.</li>
        {% endfor %}
    </ul>
    <a href="{{ url_for('categorie', {id: categorie.id}) }}">← Retour à la catégorie</a>
{% endblock %}