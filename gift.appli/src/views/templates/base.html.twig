<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}GiftBox{% endblock %}</title>
    <link rel="stylesheet" href="{{ css_dir }}/style.css">
</head>

<body>
    <div class="grid-container">
        <header>
            <h1>GiftBox App</h1>
        </header>

        <nav>
            <ul>
{% for item in nav_menu %}
                    <li><a href="{{ item.url }}">{{ item.label }}</a></li>
                {% endfor %}            </ul>
        </nav>

        <hr>
        <main>
            {% block content %}
            {% endblock %}
        </main>

        <hr>

        <footer>
            <p>ANTZORN Hugo     -    BOUDOUAH Ilias     -    AIME--CABOCEL Léandre</p>
        </footer>
    </div>
</body>
</html>