{% extends 'base.html.twig' %}

{% block title %}MyGiftBox — Coffrets cadeaux sur mesure{% endblock %}

{% block content %}

<section class="hero">
    <div class="hero-content">
        <h1>Offrez l'expérience parfaite</h1>
        <p class="hero-subtitle">Composez un coffret cadeau unique à partir de notre catalogue de prestations : activités, gastronomie, hébergement, attentions…</p>
      
    </div>
</section>

<section class="categories">
    <h2>Nos catégories de prestations</h2>
    <div class="categories-grid">
        <div class="category-card">
            <div class="category-icon">🍽️</div>
            <h3>Restauration</h3>
            <p>Restaurants gastronomiques, paniers gourmands, repas d'exception…</p>
        </div>
        <div class="category-card">
            <div class="category-icon">🏨</div>
            <h3>Hébergement</h3>
            <p>Auberges de charme, hôtels 5 étoiles, cabanes dans les arbres…</p>
        </div>
        <div class="category-card">
            <div class="category-icon">🎁</div>
            <h3>Attentions</h3>
            <p>Bouquets de fleurs, champagne, chocolats, petites surprises…</p>
        </div>
        <div class="category-card">
            <div class="category-icon">🪂</div>
            <h3>Activités</h3>
            <p>Saut en parachute, spa, soirée à l'opéra, cours de cuisine…</p>
        </div>
    </div>
</section>



{% endblock %}
